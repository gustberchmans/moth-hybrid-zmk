/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include "xiao_ble_plus-pinctrl.dtsi"

/ {
    model = "Seeed Studio XIAO nRF52840 Plus";
    compatible = "seeed,xiao-ble-plus";

    chosen {
        zephyr,sram = &sram0;
        zephyr,flash = &flash0;
        zephyr,code-partition = &code_partition;
        zephyr,console = &uart0;
    };

    leds {
        compatible = "gpio-leds";
        led0: led_0 {
            gpios = <&gpio0 26 GPIO_ACTIVE_LOW>;
            label = "Red LED";
        };
        led1: led_1 {
            gpios = <&gpio0 30 GPIO_ACTIVE_LOW>;
            label = "Green LED";
        };
        led2: led_2 {
            gpios = <&gpio0 6 GPIO_ACTIVE_LOW>;
            label = "Blue LED";
        };
    };

    xiao_d: connector {
        compatible = "seeed,xiao-gpio";
        #gpio-cells = <2>;
        gpio-map-mask = <0xffffffff 0xffffffc0>;
        gpio-map-pass-thru = <0 0x3f>;
        gpio-map =
            <0 0 &gpio0 2 0>,    /* D0  - P0.02 */
            <1 0 &gpio0 3 0>,    /* D1  - P0.03 */
            <2 0 &gpio0 28 0>,   /* D2  - P0.28 */
            <3 0 &gpio0 29 0>,   /* D3  - P0.29 */
            <4 0 &gpio0 4 0>,    /* D4  - P0.04 (SDA) */
            <5 0 &gpio0 5 0>,    /* D5  - P0.05 (SCL) */
            <6 0 &gpio1 11 0>,   /* D6  - P1.11 (TX) */
            <7 0 &gpio1 12 0>,   /* D7  - P1.12 (RX) */
            <8 0 &gpio1 13 0>,   /* D8  - P1.13 (SCK) */
            <9 0 &gpio1 14 0>,   /* D9  - P1.14 (MISO) */
            <10 0 &gpio1 15 0>,  /* D10 - P1.15 (MOSI) */
            <11 0 &gpio0 15 0>,  /* D11 - P0.15 (I2S_SD) */
            <12 0 &gpio0 19 0>,  /* D12 - P0.19 (I2S_SCK) */
            <13 0 &gpio1 1 0>,   /* D13 - P1.01 (I2S_WS) */
            <14 0 &gpio0 9 0>,   /* D14 - P0.09 (NFC1) */
            <15 0 &gpio0 10 0>,  /* D15 - P0.10 (NFC2) */
            <16 0 &gpio0 31 0>,  /* D16 - P0.31 (BAT ADC) */
            <17 0 &gpio1 3 0>,   /* D17 - P1.03 (SCK1) */
            <18 0 &gpio1 5 0>,   /* D18 - P1.05 (MISO1) */
            <19 0 &gpio1 7 0>;   /* D19 - P1.07 (MOSI1) */
    };
};

xiao_serial: &uart0 {};
xiao_i2c: &i2c0 {};
xiao_spi: &spi0 {};

&flash0 {
    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        boot_partition: partition@0 {
            label = "adafruit_boot";
            reg = <0x000000000 0x00027000>;
            read-only;
        };

        code_partition: partition@27000 {
            label = "code_partition";
            reg = <0x00027000 0x000B1000>;
        };

        storage_partition: partition@D8000 {
            label = "storage";
            reg = <0x000D8000 0x00020000>;
        };

        boot_partition_settings: partition@F8000 {
            label = "adafruit_boot_settings";
            reg = <0x000F8000 0x00008000>;
            read-only;
        };
    };
};

&gpio0 { status = "okay"; };
&gpio1 { status = "okay"; };

&uart0 {
    compatible = "nordic,nrf-uarte";
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&uart0_default>;
    pinctrl-1 = <&uart0_sleep>;
    pinctrl-names = "default", "sleep";
};

&i2c0 {
    compatible = "nordic,nrf-twi";
    status = "okay";
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
};

&spi0 {
    compatible = "nordic,nrf-spi";
    status = "okay";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
};

&usbd { status = "okay"; };
&gpiote { status = "okay"; };
